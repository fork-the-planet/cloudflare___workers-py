{
    "name": "bindings-test",
    "main": "src/worker.py",
    "compatibility_date": "%COMPAT_DATE",
    "compatibility_flags": [
        "python_workers",
        "python_workflows",
        "python_workflows_implicit_dependencies"
    ],
    "kv_namespaces": [
        { "binding": "KV", "id": "test-kv" }
    ],
    "r2_buckets": [
        { "binding": "BUCKET", "bucket_name": "test-bucket" }
    ],
    "d1_databases": [
        {
            "binding": "DB",
            "database_id": "00000000-0000-0000-0000-000000000000",
            "database_name": "test-db"
        }
    ],
    "queues": {
        "producers": [
            { "binding": "TEST_QUEUE", "queue": "test-queue" }
        ],
        "consumers": [
            { "queue": "test-queue", "max_batch_size": 10, "max_batch_timeout": 1 }
        ]
    },
    "durable_objects": {
        "bindings": [
            { "name": "TEST_DO", "class_name": "TestDurableObject" }
        ]
    },
    "migrations": [
        { "tag": "v1", "new_sqlite_classes": ["TestDurableObject"] }
    ],
    "workflows": [
        {
            "name": "test-workflow",
            "binding": "MY_WORKFLOW",
            "class_name": "TestWorkflow"
        }
    ],
    "vectorize": [
        { "binding": "VECTORIZE", "index_name": "test-index" }
    ],
    "analytics_engine_datasets": [
        { "binding": "ANALYTICS", "dataset": "test-dataset" }
    ],
    "images": { "binding": "IMAGES" },
    "ratelimits": [
        { "name": "RATE_LIMITER", "namespace_id": "1001", "simple": { "period": 60, "limit": 100 } }
    ],
    "version_metadata": { "binding": "VERSION" },
    "mtls_certificates": [
        { "binding": "MY_CERT", "certificate_id": "00000000-0000-0000-0000-000000000000" }
    ],
    "assets": {
        "directory": "./public/",
        "binding": "ASSETS",
        "run_worker_first": true
    }
}
